              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "if (jsonData && jsonData.data && jsonData.data.accessToken) {",
                  "  pm.collectionVariables.set('token', jsonData.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
